# Runs the `prettier` formatter CLI as part of pre-commit; see https://github.com/prettier/prettier
set -e
script_dir="$(dirname "$(realpath "$0")")"
repo_root="$(dirname "$script_dir")"
package_name='prettier'
package_version='3.8.3'
package_sha256='c8a850e71b7366f1bac1885e05b2f929d47168009f3b6914413902ca8b980fde'
package_tarball_url="https://registry.npmjs.org/${package_name}/-/${package_name}-${package_version}.tgz"
# curl -fsSL "$package_tarball_url" | shasum -a 256 -b | sed 's/[[:blank:]].*//'  # actual value of package_sha256
package_cli="$repo_root/.venv/${package_name}/${package_name}-${package_version}/package/bin/${package_name}.cjs"
if [ ! -f "$package_cli" ]; then
    "$script_dir/install_npm_package.py" "$package_name" "$package_version" "$package_tarball_url" "$package_sha256"
fi
exec node "$package_cli" ${1+"$@"}
